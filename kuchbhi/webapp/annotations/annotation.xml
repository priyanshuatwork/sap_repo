<Annotations Target="ZStudentService.Student"
 xmlns="http://docs.oasis-open.org/odata/ns/edm">

  <!-- List Report Columns -->
  <Annotation Term="UI.LineItem">
    <Collection>
      <Record Type="UI.DataField">
        <PropertyValue Property="Value" Path="StudentID"/>
      </Record>
      <Record Type="UI.DataField">
        <PropertyValue Property="Value" Path="StudentName"/>
      </Record>
      <Record Type="UI.DataField">
        <PropertyValue Property="Value" Path="City"/>
      </Record>
      <Record Type="UI.DataField">
        <PropertyValue Property="Value" Path="Country"/>
      </Record>
    </Collection>
  </Annotation>

  <!-- Filter Bar -->
  <Annotation Term="UI.SelectionFields">
    <Collection>
      <PropertyPath>StudentName</PropertyPath>
      <PropertyPath>City</PropertyPath>
    </Collection>
  </Annotation>

</Annotations>