<mvc:View
    controllerName="demo.practice.project.controller.View3"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox 
        class="sapUiSmallMargin"
        justifyContent="Center"
        alignItems="Center">

        <Title text="Required Field Validation" 
            class="sapUiSmallMarginBottom"/>

        <Input
            id="nameInput2"
            value="{/name}"
            placeholder="Enter name"
         />
        <Input
            id="emailInput"
            value="{/email}"
            placeholder="Enter Email"
         />
        <Button 
text="Validate"
type="Emphasized"
press="onValidate"
 />

    </VBox>

</mvc:View>
