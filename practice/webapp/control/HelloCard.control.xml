<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Panel headerText="{$this>/title}" class="sapUiSmallMargin">
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="Name from XML Composite Control" />
                <Input value="{$this>/name}" editable="false" />
                <Button text="Show Message" press="onShowMessage" />
            </VBox>
        </content>
    </Panel>

</core:FragmentDefinition>